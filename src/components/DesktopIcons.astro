---
import DesktopLinkIcon from './DesktopLinkIcon.astro';
import EmbedIcon from './EmbedIcon.astro';
import BubbleIcon from './BubbleIcon.astro';
import Exporer from './explorer/Explorer.astro';
---
<div class="desktop-icons">
  <DesktopLinkIcon href="https://github.com/Minimaruva" label="GitHub" icon="fa-brands fa-square-github" color="#f0f6fc"  />
  <DesktopLinkIcon href="https://www.linkedin.com/in/vladyslav-yahnon-270828350/" label="LinkedIn" icon="fa-brands fa-linkedin" color="#0A66C2" />
  <EmbedIcon label="resume.pdf" icon="fa-solid fa-file-pdf" color="#ff0000">
  <embed src="/Resume_upd_Vladyslav_Yahnon.pdf" width="100%" height="900px" type="application/pdf" />
  </EmbedIcon>
  <EmbedIcon label="resume.pdf" icon="fa-solid fa-file-pdf" color="#ff0000">
  <embed src="/Resume_upd_Vladyslav_Yahnon.pdf" width="100%" height="900px" type="application/pdf" />
  </EmbedIcon>
  <EmbedIcon label="me.jpg" icon="fa-solid fa-file-image" color="#00000">
  <img src="/me_speech.jpg" alt="Me during speech day" style="width:1200px; height:500px;">
  </EmbedIcon>
  <BubbleIcon label="bubbles.exe" icon="fa-solid fa-wand-sparkles" color="#00aaff" />
  <EmbedIcon label="explorer.exe" icon="fa-regular fa-folder-closed" color="#00000">
    <Exporer />
  </EmbedIcon>
</div>
